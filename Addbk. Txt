  const addFileUrl =
    `${this.siteUrl}/_api/web/GetFolderByServerRelativeUrl('${folderPath}')/Files/add(url='${fileName}',overwrite=false)`;

  const fileContent = new Blob(['audit'], { type: 'text/plain' });

  return this.getFormDigest().pipe(
