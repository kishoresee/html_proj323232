createPerformanceIssueItem(
  employeeUid: string,
  payload: any,
  parentId: string
): Observable<any> {

  const libraryName = 'PerformanceIssuesLib';
  const entityType = 'SP.Data.PerformanceIssuesLibItem';

  const employeeFolder =
    `/sites/PIPWorkflow/${libraryName}/${employeeUid}`;

  const pipFolder =
    `${employeeFolder}/${parentId}`;

  return this.ensureFolder(employeeFolder).pipe(

    // Ensure PIP subfolder
    switchMap(() => this.ensureFolder(pipFolder)),

    // Get Digest
    switchMap(() => this.getFormDigest()),

    // Upload file
    switchMap(digest => {

      const fileName = `issue_${Date.now()}.txt`;

      const uploadUrl =
        `${this.siteUrl}/_api/web/GetFolderByServerRelativeUrl('${pipFolder}')/Files/add(url='${fileName}',overwrite=true)`;

      const headers = new HttpHeaders({
        Accept: 'application/json;odata=verbose',
        'Content-Type': 'application/octet-stream',
        'X-RequestDigest': digest
      });

      const emptyBlob = new Blob([''], { type: 'application/octet-stream' });

      return this.http.post<any>(uploadUrl, emptyBlob, {
        headers,
        withCredentials: true
      }).pipe(
        map(res => ({
          fileUrl: res.d.ServerRelativeUrl,
          digest
        }))
      );
    }),

    // Patch metadata
    switchMap(({ fileUrl, digest }) => {

      const patchUrl =
        `${this.siteUrl}/_api/web/GetFileByServerRelativeUrl('${fileUrl}')/ListItemAllFields`;

      const body = {
        __metadata: { type: entityType },

        PerformanceIssue_x0020_: payload.issue,
        Timeline: payload.timeline,
        PerformanceStandards: payload.standard,
        CurrentPerformanceAssessment: payload.currentAssessment,
        PerformanceParentPIPID: parentId,
        PerformanceSequence: payload.sequence
      };

      const headers = new HttpHeaders({
        Accept: 'application/json;odata=verbose',
        'Content-Type': 'application/json;odata=verbose',
        'X-RequestDigest': digest,
        'IF-MATCH': '*',
        'X-HTTP-Method': 'MERGE'
      });

      return this.http.post(patchUrl, body, {
        headers,
        withCredentials: true
      });
    })
  );
}


