})
export class PIPFormComponent implements OnInit {

  pipForm!: FormGroup;
  employees: any[] = [];
  submitted = false;

  constructor(
    private fb: FormBuilder,
    private sp: SharePointService
  ) {}

  ngOnInit(): void {
    this.buildForm();
    this.loadManagerFromSharePoint();
  }

