private sendExtendedSessionInvites(
  employeeMail: string,
  managerMail: string,
  hrbpMail: string
): void {

  const extendedSessions = this.checkInSessions.controls
    .filter(ctrl => ctrl.get('sessionSequence')?.value > 8);

  extendedSessions.forEach(ctrl => {

    const seq = ctrl.get('sessionSequence')?.value;
    const date: Date = ctrl.get('sessionDate')?.value;
    const start: Date = ctrl.get('sessionStart')?.value;
    const end: Date = ctrl.get('sessionEnd')?.value;

    if (!date || !start || !end) return;

    const startDate = new Date(date);
    startDate.setHours(start.getHours(), start.getMinutes(), 0, 0);

    const endDate = new Date(date);
    endDate.setHours(end.getHours(), end.getMinutes(), 0, 0);

    const icsContent = this.generateICS(
      `PIP Check-in Session ${seq}`,
      startDate,
      endDate,
      `${Date.now()}-${seq}`,
      employeeMail,
      managerMail,
      hrbpMail
    );

    const formData = new FormData();

    formData.append('FromEmail', environment.from_email);
    formData.append('ToEmail', employeeMail);
    formData.append('CcEmail', managerMail);
    formData.append('CcEmail', hrbpMail);
    formData.append('Subject', `PIP Check-in Session ${seq}`);
    formData.append('Body', 'Please find attached calendar invite.');
    formData.append('IsBodyHtml', 'true');
    formData.append('ClientName', 'Team PIP');

    const blob = new Blob([icsContent], { type: 'text/calendar' });

    formData.append(
      'Attachment',
      blob,
      `PIP-Session-${seq}.ics`
    );

    this.sp.sendMailWithAttachment(formData).subscribe({
      next: () => console.log(`Extended session ${seq} invite sent`),
      error: (err) => console.error(`Session ${seq} invite failed`, err)
    });

  });

}


