private generateICS(
  title: string,
  start: Date,
  end: Date,
  uid: string,
  employeeMail: string,
  managerMail: string,
  hrbpMail: string
): string {

  const format = (d: Date) =>
    d.getUTCFullYear().toString() +
    String(d.getUTCMonth() + 1).padStart(2, '0') +
    String(d.getUTCDate()).padStart(2, '0') + 'T' +
    String(d.getUTCHours()).padStart(2, '0') +
    String(d.getUTCMinutes()).padStart(2, '0') +
    String(d.getUTCSeconds()).padStart(2, '0') + 'Z';

  return `BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//PIP Workflow//EN
METHOD:REQUEST
BEGIN:VEVENT
UID:${uid}
DTSTAMP:${format(new Date())}
DTSTART:${format(start)}
DTEND:${format(end)}
SUMMARY:${title}
DESCRIPTION:PIP Check-in Session
ORGANIZER;CN=PIP System:MAILTO:${environment.from_email}
ATTENDEE;CN=Employee;RSVP=TRUE:MAILTO:${employeeMail}
ATTENDEE;CN=Manager;RSVP=TRUE:MAILTO:${managerMail}
ATTENDEE;CN=HRBP;RSVP=TRUE:MAILTO:${hrbpMail}
STATUS:CONFIRMED
SEQUENCE:0
END:VEVENT
END:VCALENDAR`;
}


