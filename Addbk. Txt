  pipForm!: FormGroup;

  constructor(private fb: FormBuilder) {}

  ngOnInit(): void {
    this.pipForm = this.fb.group({
      manager: this.fb.group({
        uid: ['', Validators.required],
        name: ['', Validators.required],
        email: ['', [Validators.required, Validators.email]]
      }),

      employee: this.fb.group({
        uid: ['', Validators.required],
