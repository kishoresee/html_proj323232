import { Component, Input } from '@angular/core';
import { SharePointService } from '../../Services/sharepoint.service';
import { take, catchError } from 'rxjs/operators';
import { of } from 'rxjs';

interface AuditRow {
  Id: number;
  ActionDate: string;
  Role: string;
  Performer: string;
  ActionType: string;
  ListName: string;
  employeeUid: string;
  payload?: any;
}

interface GroupedAudit {
  employeeUid: string;
  logs: AuditRow[];
  expanded: boolean;
