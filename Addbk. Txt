          <h3>Event Details</h3>
          <p><strong>Event Name:</strong> ${title}</p>
          <p><strong>Event Description:</strong> ${description}</p>
          <p><strong>Event Rules:</strong><br>${rules.replace(/\n/g, "<br>")}</p>
          
