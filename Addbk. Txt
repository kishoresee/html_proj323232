VERSION:2.0
PRODID:-//PIP Workflow//EN
METHOD:REQUEST
BEGIN:VEVENT
UID:${uid}
DTSTAMP:${format(new Date())}
DTSTART:${format(start)}
DTEND:${format(end)}
SUMMARY:${subject}
DESCRIPTION:PIP Check-in Session
LOCATION:Microsoft Teams
STATUS:CONFIRMED
SEQUENCE:0
END:VEVENT
END:VCALENDAR
`;
}


